{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "cargo",
      "args": ["run"],
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "RSMINE__JWT__SECRET": "dev-secret-key-change-in-production",
          "RSMINE__DEBUG": "true"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "group": "dev-servers"
      },
      "problemMatcher": [],
      "isBackground": true,
      "icon": { "id": "server", "color": "terminal.ansiGreen" }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "options": {
        "cwd": "${workspaceFolder}/web"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "group": "dev-servers"
      },
      "problemMatcher": [],
      "isBackground": true,
      "icon": { "id": "zap", "color": "terminal.ansiYellow" }
    },
    {
      "label": "Start All",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "icon": { "id": "rocket", "color": "terminal.ansiBlue" }
    }
  ]
}
