[server]
host = "0.0.0.0"
port = 3001
base_url = "http://{{ ansible_host }}:3511"

[database]
url = "postgres://{{ db_user }}:{{ db_password }}@rsmine-db:5432/{{ db_name }}"
max_connections = 10

[jwt]
secret = "{{ jwt_secret }}"
expiration = 86400

[storage]
path = "./data/files"
max_file_size = 10485760

[logging]
level = "info"
format = "json"

[password]
min_length = 8
