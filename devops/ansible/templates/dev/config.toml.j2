[server]
host = "0.0.0.0"
port = 3001

[database]
url = "postgres://{{ postgres_user }}:{{ postgres_password }}@rsmine-db:5432/{{ postgres_db }}"
max_connections = 10

[jwt]
secret = "{{ jwt_secret }}"
expiration = 86400

[storage]
path = "./data/files"
max_file_size = 10485760

[logging]
level = "info"
format = "json"

[password]
min_length = 8

[cors]
allow_origins = ["{{ cors_origin }}"]
